#server bloc HTTP (80), redirect all traffic toward HTTPS, except ACME challenge requests
server {
    listen 80;
    server_name _;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

#server bloc HTTPS (443)
server {
    listen 443 ssl;
    server_name _;

    ssl_certificate /etc/letsencrypt/live/{{ stashcloud_fqdn }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ stashcloud_fqdn }}/privkey.pem;

    server_tokens off;

    # TLS hardening
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;

    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # enable HSTS 
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Prevent MIME sniffing
    add_header X-Content-Type-Options "nosniff" always;

    # Anti-clickjacking (deny framing)
    add_header X-Frame-Options "DENY" always;

    # Reduce referrer leakage
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Disable unneeded powerful browser features
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    location / {

        proxy_pass         http://filestash:8334;
        proxy_http_version 1.1;
        
        proxy_request_buffering off;
        proxy_buffering off;

        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Websocket upgrade  
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";

        proxy_read_timeout  300s;
        proxy_send_timeout  300s;
        client_max_body_size 2G;
    }
}
